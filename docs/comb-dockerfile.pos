603d0927b0a","category":"basic","locked":false,"group":""},"1761c0f28c3d4d":{"parent":"","link":"","shapeStyle":{"alpha":1},"textBlock":[{"position":{"w":"w-20","h":"h","x":10,"y":0},"text":"私有化平台的时候，开发者或者厂商有自己的镜像，然后如何做让对方的镜像符合平台使用？ 也就是&nbsp; 加上 lab和vscode"}],"anchors":[{"x":"w/2","y":"0"},{"x":"w/2","y":"h"},{"x":"0","y":"h/2"},{"x":"w","y":"h/2"}],"fontStyle":{"textAlign":"left","vAlign":"top"},"title":"矩形","dataAttributes":[{"name":"序号","id":"1761c0f29ebd87","category":"default","type":"number","value":""},{"name":"名称","id":"1761c0f29eb85a","category":"default","type":"string","value":""},{"name":"所有者","id":"1761c0f29eb4ac","category":"default","type":"string","value":""},{"name":"连接","id":"1761c0f29ebb96","category":"default","type":"link","value":""},{"name":"便笺","id":"1761c0f29ebc2e","category":"default","type":"string","value":""}],"props":{"zindex":46,"w":471.77272727272725,"h":90,"x":29.23966942148767,"angle":0,"y":363.09090909090855},"path":[{"actions":[{"x":"0","action":"move","y":"0"},{"x":"w","action":"line","y":"0"},{"x":"w","action":"line","y":"h"},{"x":"0","action":"line","y":"h"},{"action":"close"}]}],"lineStyle":{},"children":[],"resizeDir":["tl","tr","br","bl"],"name":"rectangle","fillStyle":{},"attribute":{"container":false,"rotatable":true,"visible":true,"collapsable":false,"collapsed":false,"linkable":true,"markerOffset":5},"id":"1761c0f28c3d4d","category":"basic","locked":false,"group":""},"17603d10675f16":{"parent":"","link":"","shapeStyle":{"alpha":1},"textBlock":[],"anchors":[{"x":"w/2","y":"0"},{"x":"w/2","y":"h"},{"x":"0","y":"h/2"},{"x":"w","y":"h/2"}],"fontStyle":{},"title":"","dataAttributes":[],"props":{"zindex":27,"w":474,"h":186,"x":27.5,"y":582.5,"angle":0},"path":[{"lineStyle":{"lineWidth":0},"actions":[{"x":"0","action":"move","y":"0"},{"x":"w","action":"line","y":"0"},{"x":"w","action":"line","y":"h"},{"x":"0","action":"line","y":"h"},{"action":"close"}]}],"lineStyle":{},"children":[],"resizeDir":["tl","tr","br","bl"],"name":"standardImage","fillStyle":{"imageW":707,"display":"stretch","imageH":308,"type":"image","fileId":"http://cdn.processon.com/5fbf70e75653bb1d54fc11c9?e=1606385399&amp;token=trhI0BY8QfVrIGn9nENop6JAc6l5nZuxhjQ62UfM:w-08p3bNY6crZx14x_ZEylcJ3lA="},"attribute":{"container":false,"rotatable":true,"visible":false,"collapsable":false,"collapsed":false,"linkable":true,"markerOffset":5},"id":"17603d10675f16","category":"standard","locked":false,"group":""},"1761be47814e3f":{"parent":"","link":"","shapeStyle":{"alpha":1},"textBlock":[{"position":{"w":"w-20","h":"h","x":10,"y":0},"text":"页面分布情况<div>1. 创建dockerfile的页面</div><div>2. 构建镜像页面</div><div>&nbsp; &nbsp; 2.1 单独层的代理使用</div><div>&nbsp; &nbsp; 2.2 如果第二层开始构建，可以选择基础镜像。并且选择后，需要跟 level匹配起来</div><div>&nbsp; &nbsp; 2.3 构建按钮点击后，需要提示每一层的镜像名称，构建的时候发现前面几层是有镜像名的，应该询问是否重新构建。因为镜像会被定时的删除掉，保证磁盘空间的问题</div><div>&nbsp; &nbsp; 2.4 按钮有两个： 只生成dockerfile 和 直接构建。主要是dockerfile生成之后可以进行复制下来，并且被算法工程师进行定制化的修改。完整的dockerfile的FROM如何定制？</div><div>&nbsp; &nbsp; 2.5 构建的时候是否需要gpu</div><div>3. 日志展示页面</div><div>&nbsp; &nbsp; 3.1 如何展示？直接让用户刷新页面。并且是nginx做直接打开的操作</div><div>4. 镜像展示功能</div><div>&nbsp; &nbsp; 4.1 镜像搜索功能，或者叫过滤功能，例如算法工程师需要cuda10的版本镜像，直接过滤一下就OK。并且选择的时候，应该有对应的dockerfile进行查看是否是自己需要的镜像</div><div>&nbsp; &nbsp; 4.2 记录dockerfile。展示的时候可以查看dockerfile的具体内容，因为dockerfile会镜像被修改，应该有一处的dockerfile除非构建，不然不允许改动。</div><div><br></div>"}],"anchors":[{"x":"w/2","y":"0"},{"x":"w/2","y":"h"},{"x":"0","y":"h/2"},{"x":"w","y":"h/2"}],"fontStyle":{"textAlign":"left","vAlign":"top"},"title":"矩形","dataAttributes":[{"name":"序号","id":"1761be47815861","category":"default","type":"number","value":""},{"name":"名称","id":"1761be47815d8a","category":"default","type":"string","value":""},{"name":"所有者","id":"1761be47815baf","category":"default","type":"string","value":""},{"name":"连接","id":"1761be478156fb","category":"default","type":"link","value":""},{"name":"便笺","id":"1761be47815ef","category":"default","type":"string","value":""}],"props":{"zindex":45,"w":621,"h":280,"x":42.90909090909091,"y":899.0909090909091,"angle":0},"path":[{"actions":[{"x":"0","action":"move","y":"0"},{"x":"w","action":"line","y":"0"},{"x":"w","action":"line","y":"h"},{"x":"0","action":"line","y":"h"},{"action":"close"}]}],"lineStyle":{},"children":[],"resizeDir":["tl","tr","br","bl"],"name":"rectangle","fillStyle":{},"attribute":{"container":false,"rotatable":true,"visible":true,"collapsable":false,"collapsed":false,"linkable":true,"markerOffset":5},"id":"1761be47814e3f","category":"basic","locked":false,"group":""},"17603d748845bc":{"textBlock":[],"dataAttributes":[],"points":[{"x":1312,"y":176},{"x":1312,"y":160}],"props":{"zindex":28},"linkerType":"broken","lineStyle":{},"name":"linker","from":{"x":1281.5,"angle":3.141592653589793,"y":176,"id":"17603d0927b1f1"},"to":{"x":1342.5,"angle":0,"y":160,"id":"17603d0927b586"},"id":"17603d748845bc","text":"","locked":false,"group":""},"1761e2282e6077":{"parent":"","link":"","shapeStyle":{"alpha":1},"textBlock":[{"position":{"w":"w-20","h":"h","x":10,"y":0},"text":"镜像名设计：镜像名最长255个字符+tag 127个字符<div>方案1: 直接加上构建信息</div><div>ccr.ccs.tencentyun.com/public_images/cuda10.0-cudnn7.4.2-python3.8-opencv4.1.1-vediotools-ice-boots3.6.5-tensorflow2.3.1-openvino-labv1-coding-envv1<br></div><div><br></div><div>优点：信息明确</div><div>缺点：镜像名称太长</div><div><br></div><div>方案2: 数据库两个字段</div><div>字段1:&nbsp; &nbsp;镜像名&nbsp; &nbsp; 最后一层+之前的所有镜像的id号。例如&nbsp; &nbsp; &nbsp;python:21&nbsp; &nbsp; &nbsp; 其中2代表python36，1代表cuda10，其中ID好超过两位数，应该有下划线连接，tag字符最长127个字符，假设有十万个层级的id号，&nbsp; 全部都是6位数字，镜像共10层，那么6*10+10个连接符，如果用16进制是否可行？ 或者拼接完，直接hash成16位的字符串，或者更加直接， 直接以ID号为tag值</div><div><br></div><div>字段2:&nbsp; 镜像信息，展示镜像里面所有内容</div><div><br></div><div>优点，镜像名称很短，并且其他人拿到镜像不能直接猜测镜像，有助于印象，虽然信息也已经打在了env上了</div><div>缺点：不够直接，并且可能会有冲突的可能，所以需要在镜像名上加唯一的标识符</div><div>方案3，两个镜像名，full和short</div><div>方案4，把框架都改成首字母的方式，env加上完整框架信息<br>方案5：类似方案2，但是使用了哈希表，把镜像的构建信息放在env当中</div>"}],"anchors":[{"x":"w/2","y":"0"},{"x":"w/2","y":"h"},{"x":"0","y":"h/2"},{"x":"w","y":"h/2"}],"fontStyle":{"textAlign":"left","vAlign":"top"},"title":"矩形","dataAttributes":[{"name":"序号","id":"1761e2283dacbe","category":"default","type":"number","value":""},{"name":"名称","id":"1761e2283da4cc","category":"default","type":"string","value":""},{"name":"所有者","id":"1761e2283dadd6","category":"default","type":"string","value":""},{"name":"连接","id":"1761e2283da77b","category":"default","type":"link","value":""},{"name":"便笺","id":"1761e2283daf21","category":"default","type":"string","value":""}],"props":{"zindex":51,"w":777.2727272727273,"h":378.99983845867246,"x":670,"angle":0,"y":815},"path":[{"actions":[{"x":"0","action":"move","y":"0"},{"x":"w","action":"line","y":"0"},{"x":"w","action":"line","y":"h"},{"x":"0","action":"line","y":"h"},{"action":"close"}]}],"lineStyle":{},"children":[],"resizeDir":["tl","tr","br","bl"],"name":"rectangle","fillStyle":{},"attribute":{"container":false,"rotatable":true,"visible":true,"collapsable":false,"collapsed":false,"linkable":true,"markerOffset":5},"id":"1761e2282e6077","category":"basic","locked":false,"group":""},"17618f4c79d63f":{"parent":"","link":"","shapeStyle":{"alpha":1},"textBlock":[{"position":{"w":"w-20","h":"h","x":10,"y":0},"text":"&nbsp; &nbsp; &nbsp;record<div>id</div><div>create_time</div><div>update_time</div><div>delete_time</div><div>image_info</div><div>image_name</div><div>combination_id</div><div>push_status<br>is_last_level 0代表不是，1代表是</div><div><br></div>"}],"anchors":[{"x":"w/2","y":"0"},{"x":"w/2","y":"h"},{"x":"0","y":"h/2"},{"x":"w","y":"h/2"}],"fontStyle":{"size":13,"textAlign":"left","vAlign":"top"},"title":"矩形","dataAttributes":[{"name":"序号","id":"17618f4c898cf7","category":"default","type":"number","value":""},{"name":"名称","id":"17618f4c8982bb","category":"default","type":"string","value":""},{"name":"所有者","id":"17618f4c898ceb","category":"default","type":"string","value":""},{"name":"连接","id":"17618f4c898d73","category":"default","type":"link","value":""},{"name":"便笺","id":"17618f4c898577","category":"default","type":"string","value":""}],"props":{"zindex":35,"w":252.2224761100515,"h":167.27272727272725,"x":1950.5,"y":214,"angle":0},"path":[{"actions":[{"x":"0","action":"move","y":"0"},{"x":"w","action":"line","y":"0"},{"x":"w","action":"line","y":"h"},{"x":"0","action":"line","y":"h"},{"action":"close"}]}],"lineStyle":{},"children":[],"resizeDir":["tl","tr","br","bl"],"name":"rectangle","fillStyle":{},"attribute":{"container":false,"rotatable":true,"visible":true,"collapsable":false,"collapsed":false,"linkable":true,"markerOffset":5},"id":"17618f4c79d63f","category":"basic","locked":false,"group":""},"1761986e1d4a4b":{"parent":"","link":"","shapeStyle":{"alpha":1},"textBlock":[{"position":{"w":"w-20","h":"h","x":10,"y":0},"text":"parent_id 为 0&nbsp; &nbsp;是顶级目录，不被level_task表记录，只有 为1 或者以上才会被记录<br>parent 0 cuda&nbsp; id为1<div>parent 1 10-cudnn7.6.5&nbsp; &nbsp; id为2</div><div>(留言板表结构设计)</div><div><br></div><div>考虑：&nbsp;</div><div>1. 如果cuda分为devel和base的基础镜像，应该如何区分？是两个1级目录，还是直接version加上devel的字样？</div><div>2. opencv对于每个算法来说，安装步骤是不一定的，可以让算法工程师进行选择（自己写的dockerfile），那么可能版本就会出现 4.1.1-xxx， 4.1.1-xxx，镜像名应该如何制作？</div><div>3. 安装顺序的表应该如何固定？&nbsp; 例如cuda是顶层部署，&nbsp; ffmpeg应该部署在opencv之前，或之后？</div>"}],"anchors":[{"x":"w/2","y":"0"},{"x":"w/2","y":"h"},{"x":"0","y":"h/2"},{"x":"w","y":"h/2"}],"fontStyle":{"textAlign":"left","vAlign":"top"},"title":"矩形","dataAttributes":[{"name":"序号","id":"1761986e1d4f8c","category":"default","type":"number","value":""},{"name":"名称","id":"1761986e1d46b5","category":"default","type":"string","value":""},{"name":"所有者","id":"1761986e1d42f1","category":"default","type":"string","value":""},{"name":"连接","id":"1761986e1d4707","category":"default","type":"link","value":""},{"name":"便笺","id":"1761986e1d4608","category":"default","type":"string","value":""}],"props":{"zindex":43,"w":638,"h":239,"x":1452,"angle":0,"y":954.9997980733406},"path":[{"actions":[{"x":"0","action":"move","y":"0"},{"x":"w","action":"line","y":"0"},{"x":"w","action":"line","y":"h"},{"x":"0","action":"li